# Required — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=""

# Google OAuth (optional — needed for "Continue with Google" on login/signup)
# Get these from https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://localhost:3000/api/auth/google/callback"

# UPC product lookup (both run in parallel on every scan)
# Open Food Facts — always used, free, no key needed.
# UPCitemDB — trial endpoint used automatically with no key (100 requests/day limit).
#   Set this key to upgrade to the paid /v1 endpoint (no rate limit).
#   Get a key at: https://www.upcitemdb.com/
UPCITEMDB_API_KEY=""

# REQUIRED: set to "production" before deploying.
# Leaving this blank or set to "development" enables demo seed accounts (admin/taker/superadmin).
NODE_ENV=""

# Cloudflare tunnel hostname (optional — tightens Vite HMR allowedHosts in dev)
# Set to the exact hostname from your tunnel, e.g. my-tunnel.trycloudflare.com
TUNNEL_HOST=""

# Set to "true" to disable Vite HMR (hot module reload) in dev.
# Useful when running behind a tunnel that doesn't support WebSocket upgrades.
DISABLE_HMR=""
